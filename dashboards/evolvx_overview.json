{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "EvolvX Prometheus datasource — set to http://localhost:9090",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "EvolvX v1.3 — Pipeline execution metrics, strategy performance, and system health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "tags": [],
      "targetBlank": true,
      "title": "EvolvX UI",
      "tooltip": "Open EvolvX dashboard",
      "type": "link",
      "url": "http://localhost:3000"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Pipeline — Live Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 500 }
            ]
          },
          "unit": "currencyUSD",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(evolvx_pipeline_equity_usdt{mode=~\"$mode\", strategy_id=~\"$strategy\"})",
          "legendFormat": "Equity",
          "refId": "A"
        }
      ],
      "title": "Account Equity",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 10 }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(evolvx_pipeline_realized_pnl_usdt{strategy_id=~\"$strategy\"})",
          "legendFormat": "Realized PnL",
          "refId": "A"
        }
      ],
      "title": "Realized PnL",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.45 },
              { "color": "green", "value": 0.55 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "avg(evolvx_pipeline_win_rate_ratio{strategy_id=~\"$strategy\"})",
          "legendFormat": "Win Rate",
          "refId": "A"
        }
      ],
      "title": "Win Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.20 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "max(evolvx_pipeline_max_drawdown_ratio{strategy_id=~\"$strategy\"})",
          "legendFormat": "Max Drawdown",
          "refId": "A"
        }
      ],
      "title": "Max Drawdown",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "avg(evolvx_pipeline_sharpe_ratio{strategy_id=~\"$strategy\"})",
          "legendFormat": "Sharpe",
          "refId": "A"
        }
      ],
      "title": "Sharpe Ratio",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "evolvx_pipeline_equity_usdt{strategy_id=~\"$strategy\", mode=~\"$mode\"}",
          "legendFormat": "{{strategy_id}} / {{mode}}",
          "refId": "A"
        },
        {
          "expr": "evolvx_pipeline_realized_pnl_usdt{strategy_id=~\"$strategy\", mode=~\"$mode\"}",
          "legendFormat": "PnL {{strategy_id}}",
          "refId": "B"
        }
      ],
      "title": "Equity & Realized PnL Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "🗂 Registry — Strategy Lifecycle",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "id": 20,
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        {
          "expr": "evolvx_registry_versions_total",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Strategy Versions by Status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "id": 21,
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "increase(evolvx_registry_approved_total[30d])",
          "legendFormat": "Approvals (30d)",
          "refId": "A"
        }
      ],
      "title": "Human Approvals (last 30 days)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "📓 Journal — Outcomes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "increase(evolvx_journal_outcomes_total{strategy_id=~\"$strategy\"}[1h])",
          "legendFormat": "{{outcome_class}}",
          "refId": "A"
        }
      ],
      "title": "Outcomes per Hour (by class)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "id": 31,
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        {
          "expr": "increase(evolvx_outcome_realized_pnl_usdt_total{strategy_id=~\"$strategy\"}[1h])",
          "legendFormat": "{{symbol}} {{outcome_class}}",
          "refId": "A"
        }
      ],
      "title": "PnL per Hour by Symbol",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 103,
      "title": "⚙️ Optimizer — Evaluation Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "none" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 29 },
      "id": 40,
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "increase(evolvx_optimizer_promoted_total[30d])",
          "legendFormat": "Promoted (30d)",
          "refId": "A"
        }
      ],
      "title": "Candidates Promoted (30d)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 29 },
      "id": 41,
      "options": { "reduceOptions": { "calcs": ["mean"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(evolvx_optimizer_job_duration_seconds_bucket[24h]))",
          "legendFormat": "p95 Job Duration",
          "refId": "A"
        }
      ],
      "title": "Optimizer Job Duration p95",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "title": "🌊 Regime — Market Conditions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 34 },
      "id": 50,
      "options": { "legend": { "displayMode": "table" } },
      "targets": [
        {
          "expr": "evolvx_regime_current{symbol=~\"$symbol\"}",
          "legendFormat": "{{symbol}} — {{regime}}",
          "refId": "A"
        }
      ],
      "title": "Current Regime per Symbol (1 = active)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "tags": ["evolvx", "trading", "strategy"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(evolvx_pipeline_equity_usdt, strategy_id)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "strategy",
        "options": [],
        "query": { "query": "label_values(evolvx_pipeline_equity_usdt, strategy_id)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Strategy"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "mode",
        "options": [
          { "selected": false, "text": "backtest", "value": "backtest" },
          { "selected": false, "text": "paper", "value": "paper" },
          { "selected": false, "text": "live", "value": "live" }
        ],
        "query": "backtest,paper,live",
        "type": "custom",
        "label": "Mode"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(evolvx_regime_current, symbol)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "symbol",
        "options": [],
        "query": { "query": "label_values(evolvx_regime_current, symbol)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query",
        "label": "Symbol"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EvolvX — Trading OS Overview",
  "uid": "evolvx-overview-v13",
  "version": 1
}
